APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
VIEW_COMPILED_PATH=storage/framework/views

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Use "log" locally (emails in storage/logs/laravel.log). Use "smtp" with real credentials in production.
MAIL_DRIVER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

AI_DEFAULT_PROVIDER=openai
AI_FALLBACK_PROVIDER=oss
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OSS_AI_BASE_URL=
OSS_AI_API_KEY=
OSS_AI_MODEL=llama-3.1-8b-instruct
AI_ANNOUNCEMENT_PROVIDER=openai
AI_ANNOUNCEMENT_MODEL=
AI_ANNOUNCEMENT_TEMPERATURE=0.4
AI_ANNOUNCEMENT_MAX_TOKENS=500
